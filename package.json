{
  "name": "@sigvardt/meta-mcp-server",
  "version": "2.1.0",
  "description": "The most comprehensive MCP server for Meta Business Suite — 200+ tools across Facebook Pages, Instagram, Threads, Ads Manager, Commerce, Conversions API, and more",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "meta-mcp-server": "dist/index.js"
  },
  "files": [
    "dist/"
  ],
  "scripts": {
    "start": "node dist/index.js",
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "prepare": "npm run build",
    "prepublishOnly": "npm run build",
    "test": "vitest run",
    "test:live": "node scripts/live-acid-test.mjs",
    "test:watch": "vitest",
    "cleanup:orphans": "node scripts/cleanup-orphans.mjs",
    "clean": "rm -rf dist"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sigvardt/meta-mcp-server.git"
  },
  "license": "MIT",
  "author": "sigvardt",
  "bugs": {
    "url": "https://github.com/sigvardt/meta-mcp-server/issues"
  },
  "homepage": "https://github.com/sigvardt/meta-mcp-server#readme",
  "keywords": [
    "mcp",
    "meta",
    "facebook",
    "instagram",
    "threads",
    "ads-manager",
    "graph-api",
    "model-context-protocol",
    "claude",
    "ai-tools"
  ],
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.6.1",
    "axios": "^1.7.9",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^4.1.0"
  }
}
